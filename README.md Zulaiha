class Complex:
    def__init__(self, real, imag):
       self.real = real
       self.imag = imag
    def__add__(self, other):
       return Complex(self.real + other.real, self.imag + other.imag)
       
    def__str__(self):
       return f"{self.real} + {self.imag}i"
c1 = Complex(2, 3)
c2 = Complex(1, 4)
print(c1 + c2) # 3 + 7i
